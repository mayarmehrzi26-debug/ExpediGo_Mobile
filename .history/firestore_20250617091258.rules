rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===== RÈGLES GÉNÉRALES =====
    match /{document=**} {
      allow read, write: if false; // Désactive l'accès global par défaut
    }
  // ===== RÈGLES POUR LES CLIENTS =====
    match /clients/{clientId} {
      allow create: if request.auth != null;
      allow read, update: if resource.data.createdBy == request.auth.uid;
    }
  

    // ===== RÈGLES POUR LES UTILISATEURS =====
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // ===== RÈGLES POUR LES COMPTEURS =====
    match /counters/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ===== RÈGLES POUR LES CONVERSATIONS =====
    match /conversations/{conversationId} {
      allow create: if request.auth != null && 
                    request.resource.data.participants.hasAny([request.auth.uid]);
      allow read: if request.auth != null && 
                  request.auth.uid in resource.data.participants;
      allow update: if request.auth != null &&
                   request.auth.uid in resource.data.participants &&
                   request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt']);
      
      match /messages/{messageId} {
        allow read: if request.auth != null && 
                    request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.sender &&
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
                      request.resource.data.keys().hasOnly(['text', 'sender', 'createdAt', 'read']) &&
                      request.resource.data.text is string;
      }
    }

    // ===== RÈGLES POUR LES LIVRAISONS =====
    match /livraisons/{livraisonId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
                    (request.auth.uid == resource.data.clientId || 
                     request.auth.uid == resource.data.livreurId ||
                     resource.data.createdBy == request.auth.uid);
    }

    // ===== RÈGLES POUR LES ADRESSES =====
    match /adresses/{adresseId} {
      allow read, write: if request.auth != null;
    }

    // ===== RÈGLES POUR LES PRODUITS =====
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ===== RÈGLES POUR LES LOGS D'ACTIVITÉ =====
    match /activity_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // ===== RÈGLES POUR LES NOTIFICATIONS =====
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ===== RÈGLES POUR LES STATISTIQUES =====
    match /stats/{document} {
      allow read: if true;
      allow write: if false;
    }

    // ===== RÈGLES POUR LES PARAMÈTRES =====
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ===== RÈGLES POUR LES FICHIERS UTILISATEUR =====
    match /user_files/{fileId} {
      allow read: if request.auth != null && 
                  (resource.data.ownerId == request.auth.uid || 
                   resource.data.sharedWith.hasAny([request.auth.uid]));
      allow write: if request.auth != null && 
                   request.auth.uid == resource.data.ownerId;
    }

    // ===== RÈGLES POUR LES POSITIONS DES LIVREURS =====
    match /livreurLocations/{livreurId} {
      allow write: if request.auth != null && 
                   request.auth.uid == livreurId &&
                   request.resource.data.latitude is number &&
                   request.resource.data.longitude is number &&
                   (request.resource.data.commandeId == null || request.resource.data.commandeId is string) &&
                   (request.resource.data.status == null || request.resource.data.status is string);
      
      allow read: if request.auth != null && 
                  (request.auth.uid == livreurId ||
                   isAdmin() ||
                   (resource.data.commandeId != null && 
                    get(/databases/$(database)/documents/livraisons/$(resource.data.commandeId)).data.clientId == request.auth.uid));
    }

    // ===== RÈGLES POUR LES TRANSACTIONS =====
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if request.auth != null 
                   && resource.data.userId == request.auth.uid
                   && request.resource.data.status == "En attente";
    }
    
    // ===== RÈGLES POUR LES DEMANDES DE RETRAIT =====
    match /withdrawalRequests/{requestId} {
      allow create: if request.auth != null 
                   && request.auth.uid == request.resource.data.userId
                   && request.resource.data.amount is number
                   && request.resource.data.amount > 0
                   && (request.resource.data.paymentMethod in ["Espèces", "Virement"] || request.resource.data.paymentMethod == null);
      
      allow read: if request.auth != null 
                 && request.auth.uid == resource.data.userId;
    }

    // ===== RÈGLES POUR LES ÉCHANGES =====
    match /exchanges/{exchangeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.commandeId != null
                    && request.resource.data.productId != null;
      allow update: if request.auth != null 
                    && (resource.data.expediteurId == request.auth.uid 
                        || resource.data.requestedBy == request.auth.uid);
    }

    // ===== FONCTIONS UTILITAIRES =====
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    function isValidAmount(amount) {
      return amount is number && amount > 0 && amount <= 10000;
    }

    function isUserOrAdmin(userId) {
      return request.auth != null && (request.auth.uid == userId || isAdmin());
    }
  }
}