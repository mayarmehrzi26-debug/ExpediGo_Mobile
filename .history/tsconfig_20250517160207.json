{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext"],
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@types/react-native": ["node_modules/@types/react-native"],
      "react-native": ["node_modules/react-native"],
      "react-native-vector-icons": ["node_modules/react-native-vector-icons"]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./src/@types"
    ]
  },
  "exclude": [
    "node_modules",
    "**/node_modules/*",
    "**/__tests__/*"
  ]
}